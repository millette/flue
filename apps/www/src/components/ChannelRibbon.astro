---
// Channel logo ribbon for the blog. Reuses the homepage ecosystem tile
// treatment, populated from the shared catalog's `channels` list.
import { channels } from "../../../ecosystem-catalog";

const items = channels.filter((channel) => channel.icon);
---

<div class="my-7 grid grid-cols-5 justify-items-center gap-3 sm:grid-cols-7">
  {items.map((app) => (
    <a href={app.href} aria-label={app.name} title={app.name} class="group block w-full max-w-[64px]">
      <span
        class="grid aspect-square place-items-center overflow-hidden rounded-[22%] border border-gray-950/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.24),0_1px_2px_rgba(17,24,39,0.12),0_4px_10px_rgba(17,24,39,0.1)] transition duration-200 group-hover:scale-105 group-hover:border-blue-600/60"
        style={`background: ${app.background}`}
      >
        <img
          class:list={[
            "object-contain",
            app.iconClass?.includes("ecosystem-logo-large")
              ? "h-[82%] w-[82%]"
              : app.iconClass?.includes("ecosystem-logo-small")
                ? "h-[48%] w-[48%]"
                : "h-[61%] w-[61%]",
            (app.iconClass?.includes("monochrome-white") || app.iconClass?.includes("invert")) && "brightness-0 invert",
          ]}
          src={app.icon}
          alt=""
          loading="lazy"
        />
      </span>
    </a>
  ))}
</div>
