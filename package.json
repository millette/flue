{
	"name": "flue",
	"type": "module",
	"private": true,
	"license": "Apache-2.0",
	"packageManager": "pnpm@11.1.1",
	"engines": {
		"node": ">=22",
		"pnpm": ">=11 <12"
	},
	"scripts": {
		"dev": "turbo dev --filter=!apps-www",
		"build": "turbo build --filter=!apps-www",
		"test": "turbo test --filter=!apps-www",
		"check": "turbo run build check:lint check:types test --filter=!apps-www",
		"check:lint": "biome lint .",
		"check:types": "turbo run check:types --filter=!apps-www",
		"format": "turbo run format:lint format:style",
		"format:lint": "biome check . --write",
		"format:style": "prettier . --cache --write --list-different"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@flue/runtime": "workspace:*",
		"@types/node": "^22.10.10",
		"bgproc": "^0.2.0",
		"prettier": "^3.4.2",
		"tsx": "^4.19.2",
		"turbo": "^2.3.3",
		"typescript": "^5.9.2"
	},
	"dependencies": {
		"just-bash": "^2.14.2"
	},
	"pnpm": {
		"overrides": {
			"typescript": "5.9.3"
		}
	}
}
